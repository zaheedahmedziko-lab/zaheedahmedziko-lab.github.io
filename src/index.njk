  </div>
</section>

<section class="content-section split-section reveal">
  <div>
    <p class="eyebrow">Latest Updates</p>
    <h2>Blog and Towson Experience</h2>
    <p>
      I use the blog section to share selected updates about my academic journey,
      research activities, teaching experience, campus life, and reflections from Towson University.
    </p>
  </div>

  <div class="latest-posts">
    {% for post in collections.blog | slice(0, 3) %}
      <article class="mini-post">
        <p>{{ post.date | readableDate }}</p>
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <span>{{ post.data.summary }}</span>
      </article>
    {% endfor %}
  </div>
</section>